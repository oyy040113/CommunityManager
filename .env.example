# ===========================
# Server
# ===========================
SERVER_PORT=8080

# ===========================
# Database (SQLite)
# ===========================
DB_URL=jdbc:sqlite:/data/community.db

# ===========================
# JPA
# ===========================
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ===========================
# JWT  (change this to a long random string in production!)
# ===========================
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_256_BITS_MIN
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ===========================
# File Upload
# ===========================
FILE_UPLOAD_DIR=/app/uploads
FILE_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,doc,docx
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=20MB

# ===========================
# Logging
# ===========================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN
